{
  "name": "invoice-extraction",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:clean": "kill-port 3000 3001 && turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "start:web": "pnpm --filter web dev",
    "start:api": "pnpm --filter api start:dev",
    "db:migrate": "pnpm --filter api prisma migrate deploy",
    "db:seed": "pnpm --filter api tsx prisma/seed.ts"
  },
  "devDependencies": {
    "kill-port": "^2.0.1",
    "prisma": "^5.19.1",
    "tsx": "^4.19.1",
    "turbo": "^2.0.14",
    "typescript": "5.9.2"
  }
}
